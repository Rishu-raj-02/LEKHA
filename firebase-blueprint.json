{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "Details of the shop and its owner",
      "type": "object",
      "properties": {
        "shop_name": { "type": "string", "description": "Name of the shop" },
        "owner_name": { "type": "string", "description": "Name of the shop owner" },
        "phone": { "type": "string", "description": "Owner's phone number" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["shop_name", "owner_name", "phone", "created_at"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Details of a customer",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the customer" },
        "phone": { "type": "string", "description": "Customer's phone number" },
        "total_udhar": { "type": "number", "description": "Total pending credit" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["name", "phone", "total_udhar", "created_at"]
    },
    "Product": {
      "title": "Product",
      "description": "Details of a product",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "price": { "type": "number", "description": "Price of the product" },
        "category": { "type": "string", "description": "Category of the product" }
      },
      "required": ["name", "price"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Details of a bill",
      "type": "object",
      "properties": {
        "customer_id": { "type": "string", "description": "ID of the customer" },
        "total_amount": { "type": "number", "description": "Total amount of the bill" },
        "status": { "type": "string", "enum": ["paid", "pending"], "description": "Payment status of the bill" },
        "items": {
          "type": "array",
          "items": { "$ref": "BillItem" },
          "description": "List of items in the bill"
        },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["customer_id", "total_amount", "items", "created_at"]
    },
    "BillItem": {
      "title": "BillItem",
      "description": "Item in a bill",
      "type": "object",
      "properties": {
        "product_name": { "type": "string", "description": "Name of the product" },
        "price": { "type": "number", "description": "Price at the time of billing" },
        "quantity": { "type": "number", "description": "Quantity purchased" }
      },
      "required": ["product_name", "price", "quantity"]
    },
    "Udhar": {
      "title": "Udhar",
      "description": "Credit entry for a customer",
      "type": "object",
      "properties": {
        "customer_id": { "type": "string", "description": "ID of the customer" },
        "amount": { "type": "number", "description": "Amount of credit" },
        "status": { "type": "string", "enum": ["pending", "paid"], "description": "Status of the credit" },
        "due_date": { "type": "string", "format": "date", "description": "Optional due date for the udhar" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["customer_id", "amount", "status", "created_at"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Shop profiles"
    },
    "/shops/{shopId}/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customers belonging to a shop"
    },
    "/shops/{shopId}/products/{productId}": {
      "schema": "Product",
      "description": "Products belonging to a shop"
    },
    "/shops/{shopId}/bills/{billId}": {
      "schema": "Bill",
      "description": "Bills generated by a shop"
    },
    "/shops/{shopId}/bills/{billId}/items/{itemId}": {
      "schema": "BillItem",
      "description": "Items within a specific bill"
    },
    "/shops/{shopId}/udhar/{udharId}": {
      "schema": "Udhar",
      "description": "Credit entries for a shop's customers"
    }
  }
}
