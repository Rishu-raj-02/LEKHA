rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isShopOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 &&
             data.phone is string && data.phone.size() >= 10 &&
             data.total_udhar is number &&
             data.created_at is timestamp;
    }

    function isValidBill(data) {
      return data.customer_id is string &&
             data.total_amount is number && data.total_amount >= 0 &&
             data.created_at is timestamp;
    }

    function isValidUdhar(data) {
      return data.customer_id is string &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'paid'] &&
             data.created_at is timestamp;
    }

    match /shops/{shopId} {

      allow read: if isShopOwner(shopId);
      allow create: if isShopOwner(shopId);
      allow update: if isShopOwner(shopId);

      // Customers
      match /customers/{customerId} {
        allow read: if isShopOwner(shopId);
        allow create: if isShopOwner(shopId) && isValidCustomer(request.resource.data);
        allow update: if isShopOwner(shopId);
        allow delete: if isShopOwner(shopId);
      }

      // Bills
      match /bills/{billId} {
        allow read: if isShopOwner(shopId);
        allow create: if isShopOwner(shopId) && isValidBill(request.resource.data);
        allow update: if isShopOwner(shopId);
        allow delete: if isShopOwner(shopId);

        match /items/{itemId} {
          allow read, write: if isShopOwner(shopId);
        }
      }

      // Udhar
      match /udhar/{udharId} {
        allow read: if isShopOwner(shopId);
        allow create: if isShopOwner(shopId) && isValidUdhar(request.resource.data);
        allow update: if isShopOwner(shopId);
        allow delete: if isShopOwner(shopId);
      }

      // Products
      match /products/{productId} {
        allow read, write: if isShopOwner(shopId);
      }
    }
  }
}